DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-client-id
DISCORD_GUILD_ID=your-test-server-id
PREFIX=-
SUPPORT_ROLE_ID=optional-support-role-id
TICKET_CATEGORY_ID=optional-ticket-category-id
LOG_CHANNEL_ID=optional-log-channel-id
AUTOMOD_ENABLED=true
AUTOMOD_EXEMPT_ROLE_IDS=optional-role-id-1,optional-role-id-2
BLOCKED_WORDS=badword1,badword2,badword3
ALLOW_DISCORD_INVITES=false
ALLOW_EXTERNAL_LINKS=false
ALLOWED_LINK_DOMAINS=youtube.com,youtu.be,github.com
AUTOMOD_MAX_MENTIONS=5
AUTOMOD_MAX_WARNINGS_BEFORE_TIMEOUT=3
AUTOMOD_WARNING_WINDOW_MINUTES=15
AUTOMOD_WARNING_MESSAGE_SECONDS=10
AUTOMOD_TIMEOUT_MINUTES=10
AUTOMOD_CAPS_RATIO=0.7
AUTOMOD_CAPS_MIN_LETTERS=12
AUTOMOD_SPAM_WINDOW_SECONDS=8
AUTOMOD_SPAM_MAX_MESSAGES=6
AUTOMOD_DUPLICATE_MAX_MESSAGES=3
AUTOMOD_DUPLICATE_MIN_LENGTH=8
